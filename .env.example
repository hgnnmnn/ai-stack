# Copy to .env and fill in real values. .env is gitignored.

# LiteLLM master key (admin / used to issue per-Client Keys).
# Generate with: echo "sk-$(openssl rand -hex 32)"
LITELLM_MASTER_KEY=sk-CHANGE_ME

# Postgres credentials for LiteLLM's virtual Keys / spend tracking DB.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=litellm
