# Copy to .env and fill in real values. .env is gitignored.

# Loads the real GPU-passthrough Backends (issues #2/#3) alongside the base
# stack, so `docker compose up -d` (no -f flags) starts everything. Remove
# this line (or use only -f docker-compose.yml) to run the Gateway/monitoring
# stack without the Backends, e.g. against an already-running pair on :8001/:8002.
COMPOSE_FILE=docker-compose.yml:docker-compose.backends.yml

# Absolute path to the directory containing GGUF model files, mounted
# read-only into the Backends (issues #2/#3).
MODELS_DIR=/home/CHANGE_ME/models

# GGUF filenames within MODELS_DIR for each Backend, relative paths are fine.
# If a model is split into multiple shards (e.g. model-00001-of-00003.gguf),
# point at the first shard.
QWEN35_MODEL_FILE=unsloth/Qwen3.6-35B-A3B-MTP-GGUF/Qwen3.6-35B-A3B-UD-Q6_K.gguf
CODER_MODEL_FILE=unsloth/Qwen3-Coder-Next-GGUF/Qwen3-Coder-Next-UD-Q4_K_XL.gguf

# Multimodal projector for llama-qwen35's vision encoder (CONTEXT.md: Daily
# Driver, Multimodal). Without --mmproj, llama-qwen35 serves text-only.
QWEN35_MMPROJ_FILE=unsloth/Qwen3.6-35B-A3B-MTP-GGUF/mmproj-F32.gguf

# Host GIDs for /dev/dri GPU passthrough (Vulkan/RADV, ADR 0003).
# Find with: getent group render | cut -d: -f3
#            getent group video | cut -d: -f3
RENDER_GID=CHANGE_ME
VIDEO_GID=CHANGE_ME

# LiteLLM master key (admin / used to issue per-Client Keys).
# Generate with: echo "sk-$(openssl rand -hex 32)"
LITELLM_MASTER_KEY=sk-CHANGE_ME

# Postgres credentials for LiteLLM's virtual Keys / spend tracking DB.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=litellm

# Grafana admin password (Grafana is LAN-facing on :3000).
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
